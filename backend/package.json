{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "author": "FPTU Halloween",
  "description": "FPTU Halloween API Server",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint src --ext js --report-unused-disable-directives --max-warnings 0",
    "clean": "node -e \"require('fs').rmSync('build', { recursive: true, force: true }); require('fs').mkdirSync('build', { recursive: true });\"",
    "build-babel": "babel ./src -d ./build/src && babel ./server.js -o ./build/server.js",
    "build": "npm run clean && npm run build-babel",
    "start": "node ./build/server.js",
    "production": "npm run build && npm run start",
    "dev": "nodemon --exec babel-node ./server.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.22.10",
    "@payos/node": "^2.0.5",
    "@react-email/components": "^0.0.36",
    "@react-email/render": "^1.1.0",
    "@react-oauth/google": "^0.13.5",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.1",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.10",
    "@babel/core": "^7.22.10",
    "@babel/eslint-parser": "^7.22.10",
    "@babel/node": "^7.22.10",
    "@babel/plugin-transform-runtime": "^7.22.10",
    "@babel/preset-env": "^7.22.10",
    "babel-plugin-module-resolver": "^5.0.0",
    "baseline-browser-mapping": "^2.10.43",
    "eslint": "^8.47.0",
    "nodemon": "^3.1.10"
  }
}
